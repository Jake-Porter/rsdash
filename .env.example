# RuneScape 3 display name to track (required to see any data)
RSN_RS3=YourRS3Name

# Old School RuneScape display name (optional, add when OSRS support is wired in)
RSN_OSRS=

# How often to poll the public hiscores (skills + boss KC), in minutes
HISCORES_POLL_MINUTES=30

# How often to poll the Adventurer's Log activity feed (RS3 only), in minutes
FEED_POLL_MINUTES=15
